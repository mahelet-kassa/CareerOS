# Copy to .env.local and fill in. Never commit real values (NFR-S2).

# Auth.js session encryption — REQUIRED in production. Generate one with:
#   npx auth secret
AUTH_SECRET=

# Managed OIDC provider (ADR-002). Works with Amazon Cognito or Auth0:
#   Cognito: https://cognito-idp.<region>.amazonaws.com/<user-pool-id>
#   Auth0:   https://<tenant>.auth0.com
OIDC_ISSUER_URI=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# core-api base URL (server-side calls)
API_BASE_URL=http://localhost:8080
